# RDU decode image for rdu-hdi disaggregated inference.
#
# Bakes in: /opt/sambanova's Python 3.11 + torch==2.2.0+sn (from the base
# image — provenance not fully self-traced, see docs/local/DOCKERIZE_BAR2_PLAN.md
# §4.4), vllm+cpu + ai-dynamo + fast-coe's vllm-rdu + UCX/NIXL (COPIED as
# pre-built binary artifacts from wheelhouse/ and rdu-ucx-install/), AND
# coe_api/rdu_engine + the BAR2 runtime connector libs (self-built, see
# scripts/build_bar2.sh) from wheelhouse/ and rdu-runtime-install/{lib,preload}.
#
# RESOLVED (2026-07-05): earlier revisions of this image deferred coe_api/
# BAR2 to NFS mounts at container runtime (BAR2_INSTALL/BAR2_RUNTIME_LIBS/
# BAR2_PRELOAD), because self-building against two candidate SambaNova/
# software branches had hit a hard ABI/hardware blocker. That blocker
# turned out to be the wrong branch/commit entirely -- jayr's real
# BAR2_INSTALL commit (confirmed directly with him) plus his one local,
# previously-uncommitted patch (patches/software-repo/coe_api_rdutensor_dtype.patch)
# builds and runs correctly, validated end-to-end on real hardware with zero
# crashes across a full benchmark sweep. See config/versions.env's
# SOFTWARE_REPO_* comment for the exact commit and docs/local/DOCKERIZE_BAR2_PLAN.md
# for the full history. This image now bakes in ALL of it -- no NFS mount
# needed at runtime for coe_api/BAR2 (the model checkpoint and PEF still are,
# since those are large data files this image doesn't and shouldn't embed).
# The bare-metal launch/rdu_decode.sh path is deprecated in favor of this
# image (see that file's own header).
#
# RUN this image with --net=host (RoCE IP visibility, matching
# gpu_prefill.sh's own --net=host requirement) and explicit device
# passthrough for /dev/rdu, /dev/rdu_mem_map, AND /dev/infiniband (three
# separate requirements — docker-run-wrapper's automatic /import,/scratch
# NFS mounting covers none of them, and --net=host alone gives network-
# NAMESPACE visibility but not RDMA hardware access). All are world-
# accessible on this cluster (confirmed via direct inspection), so
# `--device /dev/rdu --device /dev/rdu_mem_map --device /dev/infiniband`
# needs no privileged mode — same RDMA-device pattern gpu_prefill.sh
# already uses. A k8s deployment would use the sambanova.ai/rdu-tile
# device plugin for /dev/rdu*, plus a hostPath volume for /dev/infiniband.
#
# Build (from the login node — the FROM base image brings /opt/sambanova
# along, same principle as Dockerfile.gpu bringing CUDA along via FROM
# vllm/vllm-openai; no snrdu/RDU node needed to BUILD this image, only to
# RUN it):
#   bash scripts/build_docker_rdu.sh
ARG RHEL810_DEV_IMAGE

FROM ${RHEL810_DEV_IMAGE} AS final

RUN dnf install -y git patch rdma-core libibverbs libibverbs-utils && dnf clean all

# SambaNova's RDMA userland replaces the stock rdma-core bnxt_re provider,
# which on this cluster's hardware sends usable-transport-breaking ioctls
# (confirmed by direct bare-metal comparison on sc3-s339: the stock
# libbnxt_re-rdmav34.so there is deliberately disabled -- renamed .orig --
# in favor of SambaNova's own copy at /opt/sambanova/lib/libbnxt_re-rdmav34.so,
# installed via /opt/sambanova/share/sambanova-deps-brcm-roce-userland/libbnxt_re.sh).
# Without it, UCX reports "no usable transports/devices" for bnxt_re0/2/4/6.
# rhel810-dev's base /opt/sambanova does not ship this package, so the
# library itself (not the install script) is vendored directly below
# (vendor/bnxt_re/, pulled from bare metal's /opt/sambanova/lib/).
COPY vendor/bnxt_re/libbnxt_re-rdmav34.so /tmp/libbnxt_re-rdmav34.so
COPY vendor/bnxt_re/bnxt_re.driver /tmp/bnxt_re.driver
RUN bash -c ' \
    [ -f /usr/lib64/libibverbs/libbnxt_re-rdmav34.so ] && mv /usr/lib64/libibverbs/libbnxt_re-rdmav34.so /usr/lib64/libibverbs/libbnxt_re-rdmav34.so.orig; \
    [ -f /etc/libibverbs.d/bnxt_re.driver ] && mv /etc/libibverbs.d/bnxt_re.driver /etc/libibverbs.d/bnxt_re.driver.orig; \
    cp /tmp/libbnxt_re-rdmav34.so /usr/lib64/libibverbs/libbnxt_re-rdmav34.so && \
    cp /tmp/bnxt_re.driver /etc/libibverbs.d/bnxt_re.driver && \
    rm -f /tmp/libbnxt_re-rdmav34.so /tmp/bnxt_re.driver && \
    ldconfig'

ENV PATH=/opt/sambanova/bin:$PATH
ENV PYTHONNOUSERSITE=1

# ── UCX (pre-built) ────────────────────────────────────────────────────────
COPY rdu-ucx-install/ /opt/rdu-ucx/
ENV LD_LIBRARY_PATH=/opt/rdu-ucx/lib:${LD_LIBRARY_PATH:-}
ENV UCX_MODULE_DIR=/opt/rdu-ucx/lib/ucx

# ── BAR2 runtime connector libs (self-built, see scripts/build_bar2.sh) ────
# coe_api/rdu_engine's compiled extension dynamically links against
# libc_samba_runtime.so/libcpp_samba_runtime.so at IMPORT time (confirmed via
# scripts/verify_bar2_import.sh needing LD_LIBRARY_PATH set even for a bare
# `import coe_api`, not just at actual RDU session creation) -- so these must
# be on LD_LIBRARY_PATH before rdu-decode-install-deps.sh's own import
# validation below runs. Baked in directly (27 .so files from the runtime
# 'graph' CMake target group) -- no NFS mount needed at runtime anymore.
COPY rdu-runtime-install/lib/ /opt/bar2-runtime/lib/
COPY rdu-runtime-install/preload/ /opt/bar2-runtime/preload/
# rdu_engine also transitively needs libmpi.so.12 (mpich) and a few abseil/
# circllhist libs -- confirmed via `ldd` on the built .so that these are
# genuinely required, not optional. They ship inside the rhel810-dev base
# image itself under /opt/sambanova/lib (confirmed by direct inspection),
# just not on LD_LIBRARY_PATH by default. On bare metal this is masked by
# whatever ambient LD_LIBRARY_PATH the node's own environment happens to
# already carry -- a container starts clean, so it must be added explicitly.
ENV LD_LIBRARY_PATH=/opt/bar2-runtime/lib:/opt/sambanova/lib:${LD_LIBRARY_PATH:-}

# ── Python deps (vllm+cpu, ai-dynamo, fast-coe's vllm-rdu, NIXL, patches) ──
COPY wheelhouse/ /build/wheelhouse/
COPY patches/rdu/ /build/patches/rdu/
# .dockerignore excludes fast-coe/.git/ from the build context entirely
# (keeps the context small) — scripts/build_docker_rdu.sh verifies the
# checkout is at the pinned FAST_COE_COMMIT on the login node, before this
# COPY, since the commit can't be checked here without the .git directory.
COPY fast-coe/ /build/fast-coe/

ARG RDU_TRANSFORMERS_VERSION
COPY docker/rdu-decode-install-deps.sh /build/rdu-decode-install-deps.sh
RUN chmod +x /build/rdu-decode-install-deps.sh && \
    RDU_TRANSFORMERS_VERSION="${RDU_TRANSFORMERS_VERSION}" /build/rdu-decode-install-deps.sh

COPY docker/rdu-decode-entrypoint.sh /opt/rdu-decode-entrypoint.sh
RUN chmod +x /opt/rdu-decode-entrypoint.sh

RUN rm -rf /build/wheelhouse /build/patches

ENTRYPOINT ["/opt/rdu-decode-entrypoint.sh"]
