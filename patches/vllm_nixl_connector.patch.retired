--- a/vllm/distributed/kv_transfer/kv_connector/v1/nixl_connector.py
+++ b/vllm/distributed/kv_transfer/kv_connector/v1/nixl_connector.py
@@ -85,6 +85,13 @@
 
 GET_META_MSG = b"get_meta_msg"
 
+# REGISTER_CONSUMER_MSG: sent by the RDU consumer to register with the GPU
+# producer for per-chunk KV-transfer overlap (VLLM_PD_CHUNK_OVERLAP=1).
+# The producer's _nixl_handshake_listener must handle this message type in
+# addition to GET_META_MSG, otherwise it crashes with
+# "TypeError: unhashable type: 'dict'" when the consumer registers.
+REGISTER_CONSUMER_MSG = b"register_consumer_msg"
+
 logger = init_logger(__name__)
 
 # Lazy import nixl_wrapper to avoid loading nixl_bindings if nixl is not used
@@ -605,12 +612,19 @@
         ready_event: threading.Event,
         stop_event: threading.Event,
         port: int,
+        on_register=None,
     ):
-        """Background thread for getting new NIXL handshakes."""
-        # NOTE(rob): this is a simple implementation. We will move
-        # to a better approach via HTTP endpoint soon.
+        """Background thread for getting new NIXL handshakes.
+
+        Handles two message types:
+        - GET_META_MSG: standard handshake, returns NIXL metadata for a TP rank
+        - REGISTER_CONSUMER_MSG: chunk-overlap consumer registration
+          (VLLM_PD_CHUNK_OVERLAP=1). The consumer sends its agent metadata so
+          the producer can add_remote_agent() and send per-chunk notifications.
 
-        # Listen for new requests for metadata.
+        Each message is wrapped in a try/except so a malformed frame or
+        unexpected message type never kills this daemon thread.
+        """
         host = envs.VLLM_NIXL_SIDE_CHANNEL_HOST
         path = make_zmq_path("tcp", host, port)
         logger.debug("Starting listening on path: %s", path)
@@ -624,15 +638,43 @@
                     if stop_event.is_set():
                         break
                     continue
-                # Decode the message which contains (GET_META_MSG, rank)
-                msg, target_tp_rank = msgspec.msgpack.decode(msg)
-                logger.debug(
-                    "Received message for tp rank %s",
-                    target_tp_rank,
-                )
-                if msg != GET_META_MSG:
-                    logger.warning("Connection listener got unexpected message %s", msg)
-                sock.send_multipart((identity, b"", encoded_data[target_tp_rank]))
+                try:
+                    msg_type, payload = msgspec.msgpack.decode(msg)
+                    if msg_type == GET_META_MSG:
+                        target_tp_rank = payload
+                        logger.debug(
+                            "Received message for tp rank %s", target_tp_rank
+                        )
+                        sock.send_multipart(
+                            (identity, b"", encoded_data[target_tp_rank])
+                        )
+                    elif msg_type == REGISTER_CONSUMER_MSG:
+                        # Chunk-overlap reverse registration: consumer sends
+                        # its NIXL agent metadata so the producer can
+                        # add_remote_agent() and emit per-chunk notifications.
+                        try:
+                            if on_register is not None:
+                                on_register(payload)
+                        except Exception as e:
+                            logger.warning(
+                                "[chunk_overlap] consumer registration "
+                                "handler raised: %r", e,
+                            )
+                        sock.send_multipart((identity, b"", b"ok"))
+                    else:
+                        logger.warning(
+                            "Connection listener got unexpected message %s",
+                            msg_type,
+                        )
+                        sock.send_multipart((identity, b"", b""))
+                except Exception as e:
+                    logger.warning(
+                        "[handshake_listener] dropping bad message: %r", e
+                    )
+                    try:
+                        sock.send_multipart((identity, b"", b""))
+                    except Exception:
+                        pass
 
     def get_num_new_matched_tokens(
         self, request: "Request", num_computed_tokens: int
@@ -2773,4 +2815,3 @@
         ):
             for list_item in transfer_stats_data[counter_item_key]:
                 counter_obj[engine_idx].inc(list_item)
