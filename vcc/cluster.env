#!/usr/bin/env bash
# VCC ("vc2-la-dc-*") cluster topology -- standalone bare-metal demo nodes,
# reached directly via SSH. No SLURM (no sinfo/squeue/srun/snrdu anywhere on
# either node), no shared dockerd (both nodes run rootless Podman instead --
# `docker` is a CLI shim for `podman`, confirmed identical output), and no
# /import or /scratch NFS shared with the vnc+idc login node. See
# vcc/README.md for the full deployment model, prerequisites, and the
# investigation this config is based on.
#
# Edit GPU_HOST/RDU_HOST/*_ROCE_IP for your own pair of VCC nodes -- these
# are cluster facts, not generic defaults, same spirit as config/cluster.env.

# ── Nodes (SSH aliases already configured in ~/.ssh/config) ──────────────────
GPU_HOST=vc2-la-dc-b200-h1      # 8x NVIDIA B200, RHEL 10.1, rootless Podman 5.8.3
RDU_HOST=vc2-la-dc-sn40-r1h1    # SambaNova SN40L RDU, RHEL 8.10, rootless Podman 4.9.4

# ── RoCE fabric IPs ───────────────────────────────────────────────────────────
# Confirmed live (2026-07-15): both nodes expose interfaces on the SAME
# 172.16.0.0/24 L2 fabric (GPU: ens21..27np0 -> .104-.110, RDU: snni0..14 ->
# .5-.12) -- cross-node ping from RDU_HOST to 4 different GPU_HOST addresses
# on this subnet all succeeded at 0.4-0.5ms RTT (genuine local-fabric
# latency, not routed). No VLAN/route setup needed, unlike the vnc+idc
# cluster where cross-node RoCE reachability is NOT guaranteed by node
# proximity alone (see cluster-infra-lessons memory / the sc3-c128 incident).
GPU_ROCE_IP=172.16.0.104
RDU_ROCE_IP=172.16.0.5

# ── Control plane ─────────────────────────────────────────────────────────────
# VCC has no separate login/control node the way vnc+idc does -- runs
# directly on GPU_HOST (224 CPUs, plenty of headroom) alongside the GPU
# prefill worker.
CONTROL_PLANE_HOST="$GPU_HOST"
CONTROL_PLANE_IP="$GPU_ROCE_IP"
ETCD_PORT=12379
NATS_PORT=14222
VLLM_PORT=18000

# ── GPU prefill ───────────────────────────────────────────────────────────────
# Single worker, uses the first TENSOR_PARALLEL_SIZE (config/model.env) GPUs
# of GPU_HOST's 8. Bump GPU_DEVICE_START / add a second vcc/launch/gpu_prefill.sh
# invocation with a different port/device range for 2P -- not done here, no
# evidence yet that VCC's demo workload needs more than 1P1D.
GPU_DEVICE_START=0
GPU_NIXL_PORT=5600
GPU_KV_EVENTS_PORT=5557

# ── RDU decode ────────────────────────────────────────────────────────────────
RDU_DECODE_REGISTER_TIMEOUT=1500   # seconds, ~12-14 min typical (BAR2/PEF init) -- same as vnc+idc
GPU_PREFILL_REGISTER_TIMEOUT=1800  # seconds

# ── GPU driver userspace libs (manual injection -- see vcc/README.md) ────────
# nvidia-container-toolkit/CDI is NOT installed on GPU_HOST and is not a
# blocker: confirmed live that copying these three host driver libs into a
# mounted dir + setting LD_LIBRARY_PATH at container launch gives real GPU
# compute (verified with an actual 4096x4096 matmul on B200, not just
# torch.cuda.is_available()). vcc/launch/gpu_prefill.sh populates this
# directory itself on first run (idempotent, skips if already present).
GPU_DRIVER_LIBS_DIR="/home/andyc/.vcc-nvidia-driver-libs"
