#!/usr/bin/env bash
# Model-specific configuration for the VCC deployment. Mirrors
# config/model.env's shape, but every path is VCC-node-local (no /import or
# /scratch NFS shared with vnc+idc -- see vcc/README.md) and split by which
# node actually needs to read it.

SERVED_MODEL_NAME=MiniMax-M2.7
TENSOR_PARALLEL_SIZE=4
MAX_MODEL_LEN=196608
MAX_NUM_BATCHED_TOKENS=4096
BLOCK_SIZE=64
GPU_MEMORY_UTILIZATION=0.90
MODEL_CONFIG_NAME=minimax_m2.yaml   # copied onto RDU_HOST by vcc/deploy_images.sh, see below

# ── GPU_HOST: checkpoint for the prefill engine + tokenizer ──────────────────
# Confirmed present (2026-07-15): a real, full 215GB checkpoint already
# staged at this exact path under jayr's home dir.
GPU_MODEL_PATH=/home/jayr/MiniMax-M2.7

# ── RDU_HOST: checkpoint (RDU decode reads this for tokenizer/config only --
#    --load-format dummy means it does NOT load tensor weights from here) ────
# Confirmed present (2026-07-15), same path convention config/minimax_m2.yaml
# already uses on vnc+idc (checkpoint_path: /scratch/MiniMax-M2.7-FP8-RDU-packed).
RDU_MODEL_PATH=/scratch/MiniMax-M2.7-FP8-RDU-packed

# ── RDU_HOST: PEF path -- NOT YET STAGED, see vcc/README.md ──────────────────
# The exact PEF vnc+idc's config/model.env points at (BS2 variant) was found
# on GPU_HOST at
#   /home/jayr/move_to_rdu/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608/minimax_m2_minimal_pef_dir/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608.pef
# -- wrong node (GPU_HOST, not RDU_HOST) for RDU decode to read it from.
# RDU_HOST's own /scratch (-> /var/scratch) is owned by a different
# corporate-LDAP UID/group my local VCC account (andyc, uid 1001, not in
# that group) can't write to -- confirmed via a real `mkdir` permission
# denial, not assumed. Staged under /home/andyc instead, which IS
# fully writable. This path is a placeholder until the real BS2 PEF is
# copied over -- see vcc/README.md's "Before you can actually launch" section
# for the exact rsync command. vcc/launch/rdu_decode.sh will fail its
# preflight check with a clear error if this path doesn't exist yet.
RDU_PEF_PATH=/home/andyc/minimax-m2-BS2-pef/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608.pef
