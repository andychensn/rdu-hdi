#!/usr/bin/env bash
# Version pins for rdu-hdi stack (sourced by build scripts)
# Every external dependency is pinned to an exact commit SHA or version.
# Last verified: 2026-06-29

# ── Native builds (cloned + pinned by SHA) ───────────────────────────────────
UCX_BRANCH=sn/v1.22
UCX_COMMIT=e153f2e470a9681ab253a4704682cdeff02015cb   # andychensn/ucx, validated on c129

NIXL_BRANCH=sn/rdu-working
NIXL_COMMIT=c2abc770e03b81d01e705fbc0593f0c2d1364935  # andychensn/nixl, validated on c129

# ── Benchmark tooling (cloned + pinned by SHA) ───────────────────────────────
INFERENCEX_COMMIT=37505e112673d673ce8808ebe6fbbb336bd87874  # SemiAnalysisAI/InferenceX main

# ── vllm-rdu hardware plugin ──────────────────────────────────────────────────
# Retired 2026-07-02: andychensn/vllm-rdu (standalone-repo fork) was a diverged
# reimplementation missing hdi's multi-agent NIXL/DDR-cache/cache-aware-routing
# features, root-causing crashes and reliability failures. See docs/local/PARITY_PLAN.md.
# VLLM_RDU_COMMIT=5bc4a56320a3b323011250e3d5fa652267110299  # andychensn/vllm-rdu main (retired)
FAST_COE_COMMIT=c3f335377f2a43e62cb65cf351e400368cad7e53  # sambanova/fast-coe, ...revert_bs2 branch — hdi's exact proven vllm-rdu (server/vllm-rdu)

# ── SambaFlow / coe_api (self-built from source, replaces BAR2_* NFS deps) ───
# SambaNova/software. Builds both the coe_api/rdu_engine Python wheel
# (Bazel) and the runtime connector libs (CMake, runtime/ 'graph' target
# group) from this SAME commit, to avoid a cross-version ABI mismatch
# between the two build systems. See docs/local/DOCKERIZE_BAR2_PLAN.md.
#
# Switched 2026-07-04 from josephp/nova/scattergather_integration (the
# team's originally-designated branch) to guoyaof/ddr-rdma-direct — the
# branch that already produced the known-working sw_ddr_rdma runtime tree.
# josephp's branch built and imported fine (after the coe_api_py311_wheel +
# extra-runtime-libs + ts16/HAL fixes below) but reproducibly crashed with
# `nixl._bindings.nixlNotFoundError: NIXL_ERR_NOT_FOUND` in
# connector_override.py's make_prepped_xfer on every 2nd real inference
# request — 100% reproducible across many fresh engine restarts, with the
# exact same unmodified fast-coe connector code that runs 9/9 benchmark
# configs with zero crashes against jayr's older coe_api. Two hypotheses
# (BAR2 slab VA drift from tensor_copy_graph teardown; a bug specific to
# the multi-DP-group cache-aware-routing NIXL descriptor path) were tested
# with diagnostic logging and disabling cache-aware routing, respectively —
# both disproved (VAs identical across requests; crash persists with
# num_dp_groups=1). guoyaof/ddr-rdma-direct's recent git log includes
# "[coe_api] Memoize memcopy schedules process-wide across materialize()"
# and "[coe_api] tensor_copy materialize: address-coalesce + size-bucketed
# launches" — directly relevant to the exact materialize()/tensor_copy
# codepath implicated in the crash, making it the more promising branch to
# retest against rather than continuing to binary-search josephp's C++.
SOFTWARE_REPO_URL=git@github.sambanovasystems.com:SambaNova/software.git
SOFTWARE_REPO_BRANCH=guoyaof/ddr-rdma-direct
SOFTWARE_REPO_COMMIT=19c8876674ebeee4240ab34a3818fb7ff1a2aa93

# OUTCOME (2026-07-04): guoyaof/ddr-rdma-direct was retested per the reasoning above and ALSO hit a
# hard blocker -- a real RDU hardware tile fault at this commit, not another software-level crash.
# Self-build of coe_api/BAR2 runtime is DEFERRED as a project decision after both candidate branches
# failed; config/cluster.env's BAR2_INSTALL/BAR2_RUNTIME_LIBS/BAR2_PRELOAD were reverted to the
# original working NFS paths (jayr's/guoyaof's prebuilt trees) and Dockerfile.rdu supplies them at
# container runtime from those same NFS paths, not from a self-built artifact. The pins above are
# NOT the active runtime configuration -- kept only as a starting point if self-build is revisited.
# scripts/build_bar2.sh/scripts/verify_bar2_import.sh (which consume these pins) are unused reference
# material for the same reason. See docs/local/DOCKERIZE_BAR2_PLAN.md's "Execution update" section.

# bazelisk: neither the login node nor RDU nodes have `bazel` on PATH by
# default. bazelisk reads the software repo's own .bazelversion (8.5.1) and
# transparently downloads/caches the matching real bazel release.
BAZELISK_VERSION=1.20.0
BAZELISK_URL=https://github.com/bazelbuild/bazelisk/releases/download/v1.20.0/bazelisk-linux-amd64
BAZELISK_SHA256=d9af1fa808c0529753c3befda75123236a711d971d3485a390507122148773a3

# rhel810-dev: SambaNova's officially-supported dev container. Has
# /opt/sambanova (torch==2.2.0+sn, mpich, llvm19) already correctly
# populated -- used both as the BAR2 self-build container (scripts/build_bar2.sh)
# and as Dockerfile.rdu's base image, so the RDU decode image doesn't need
# to separately source torch's provenance (still not fully traced per
# docs/local/DOCKERIZE_BAR2_PLAN.md Section 4.4).
RHEL810_DEV_IMAGE=artifacts.sambanovasystems.com/sw-docker/rhel810-dev:latest

# ── Python packages ───────────────────────────────────────────────────────────
# GPU side: torch/flashinfer/deepgemm are locked inside vllm/vllm-openai Docker image.
VLLM_VERSION=0.16.0           # vllm Docker image base tag
DYNAMO_VERSION=1.2.1          # ai-dynamo + ai-dynamo-runtime (control plane + RDU venv)

# ── Python packages — RDU side ────────────────────────────────────────────────
RDU_NUMPY_VERSION=1.26.4      # CRITICAL: system numpy 2.x binary-incompatible with torch 2.2.0+sn
RDU_TRANSFORMERS_VERSION=4.56.0

# ── rdma-core devel headers (downloaded by build_rdu_env.sh --fetch-only,
#    SHA256-verified). RHEL8 RDU nodes ship libibverbs/librdmacm runtime .so.1
#    (matching this exact version, confirmed via SONAME 1.14.48.0/1.3.48.0)
#    but not the -devel headers, and no package manager access to install them.
#    We only need a handful of public headers to compile UCX's verbs transport
#    against — see scripts/build_rdu_env.sh for the exact file list.  ──
RDMA_CORE_VERSION=48.0
RDMA_CORE_URL=https://github.com/linux-rdma/rdma-core/archive/refs/tags/v48.0.tar.gz
RDMA_CORE_SHA256=e78abaa3ed16771bc6c40b538fe27082429363b86b6ce47636bb57a59238b2be

# ── Infrastructure (downloaded by scripts/fetch_vendor.sh, SHA256-verified) ──
ETCD_VERSION=3.5.15
ETCD_URL=https://github.com/etcd-io/etcd/releases/download/v3.5.15/etcd-v3.5.15-linux-amd64.tar.gz
ETCD_SHA256=435d74510f3216bab1932fb6d7a6b5fe8245301143fcd25f7e65dfb7dcf8904a

NATS_VERSION=2.14.3
NATS_URL=https://github.com/nats-io/nats-server/releases/download/v2.14.3/nats-server-v2.14.3-linux-amd64.tar.gz
NATS_SHA256=588b858328bc507ddff3b6078cda7db762f28e6da8c3fa368099a204f0f37a37
