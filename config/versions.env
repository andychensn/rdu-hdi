#!/usr/bin/env bash
# Version pins for rdu-hdi stack (sourced by build scripts)
# Every external dependency is pinned to an exact commit SHA or version.
# Last verified: 2026-07-05

# ── Native builds (cloned + pinned by SHA) ───────────────────────────────────
# open-source/ucx, SambaNova org fork. This exact commit is the tip of the
# org fork's sambanova/rdu branch.
UCX_URL=git@github.sambanovasystems.com:open-source/ucx.git
UCX_BRANCH=sambanova/rdu
UCX_COMMIT=e153f2e470a9681ab253a4704682cdeff02015cb   # validated on c129

# open-source/nixl, SambaNova org fork, re-validated end-to-end (image
# build + live GPU-prefill/RDU-decode registration + a real
# 100k-input/1k-output-token benchmark) before switching.
NIXL_URL=git@github.sambanovasystems.com:open-source/nixl.git
NIXL_BRANCH=sambanova/rdu
NIXL_COMMIT=780a10fe7bc6d73208b6f11e45f68b2a763fe731  # sambanova/rdu tip as of 2026-07-14, validated on c129

# ── Benchmark tooling (cloned + pinned by SHA) ───────────────────────────────
INFERENCEX_URL=https://github.com/SemiAnalysisAI/InferenceX.git
INFERENCEX_BRANCH=main
INFERENCEX_COMMIT=37505e112673d673ce8808ebe6fbbb336bd87874

# ── vllm-rdu hardware plugin ──────────────────────────────────────────────────
# sambanova/vllm-rdu -- the RDU decode worker (RDUWorker/RDUModelRunner/
# NixlConnector), replacing fast-coe's server/vllm-rdu as of this pin.
# Pinned to a branch off vllm-rdu's own `main` carrying exactly three
# changes, each independently justified and live-tested:
#   - RDUWorker.profile() API-triggered rdu_engine tracing (a standalone
#     HTTP control server, since headless dynamo.vllm workers never
#     instantiate vLLM's own FastAPI server).
#   - RDU_ENGINE_TARGET_RUNTIME_VERSION_OVERRIDE (see below).
#   - Don't BAR2-map the model's own paged K/V cache when DDR prefix-cache
#     is enabled (Task.get_paged_key_cache/get_paged_value_cache,
#     bar2_map=False by default). Confirmed empirically necessary
#     2026-07-15: removing it (keeping the other two changes, plus our own
#     build's staged memcopy/scatter-gather utility PEFs) reproduces
#     "sn_client_get_bar2_va: ATR mapping failed" on the DDR-cache's own
#     ~30GB/vsnode ddr_tensor(bar2=True) allocation -- the eager,
#     unconditional paged-cache BAR2 mapping pre-consumes vsnode 0's
#     BAR2/ATR aperture first. Re-added as its own commit once isolated.
# An earlier version of this branch also carried a begin/finalize_configuration
# wrap and memcopy/scatter-gather PEF bundle-path overrides, both dropped:
# the former had no measurable effect (live-tested), and the latter is now
# handled entirely by our own build staging these utility PEFs directly
# (see build/bar2.sh's stage_utility_pefs) rather than needing any
# vllm-rdu-side toggle.
# PR: https://github.com/sambanova/vllm-rdu/pull/159 (re-pin to a post-merge
# main commit once it lands there).
VLLM_RDU_URL=git@github.com:sambanova/vllm-rdu.git
VLLM_RDU_BRANCH=andyc/hdi-integration
VLLM_RDU_COMMIT=dcc3a4df5f92fc00f349aa5e1dff78993b2d6da4

# This branch's coe_api supported-runtime-version allowlist doesn't include
# 1.33.1, the version our production PEF (config/model.env's PEF) was
# compiled against, and vllm-rdu's rdu_executor/runtime.py itself hardcodes
# a request for exactly "1.33.1" -- 1.34.0 is the nearest supported version.
# Confirmed working live against vllm-rdu directly (2026-07-15): PEF
# registration (coe_api's "Adding PEF ... with ID 0" log line) proceeds
# without the "target runtime version 1.33.1 is not supported" rejection
# that occurs without this override. Consumed by rdu_executor/runtime.py --
# only takes effect for this deployment, not other vllm-rdu consumers.
RDU_ENGINE_TARGET_RUNTIME_VERSION_OVERRIDE=1.34.0

# ── SambaFlow / coe_api (self-built from source, replaces BAR2_* NFS deps) ───
# SambaNova/software. Builds both the coe_api/rdu_engine Python wheel
# (Bazel) and the runtime connector libs (CMake, runtime/ 'graph' target
# group) from this SAME commit, to avoid a cross-version ABI mismatch
# between the two build systems (build/bar2.sh).
#
# Points at josephp's branch (DDR alloc mem2mem, bar2 mappings, scaleout
# refactor, ATR patch, ScatterGatherGraph) per direct guidance to move
# here. Our own `.dtype` property patch on CoETensor/RDUTensor
# (frontend/nova/coe_api/src/lib/py_coe_api.cpp, previously
# andyc/coe_api_rdutensor_dtype @ f232d815) is not lost -- confirmed via
# `git merge-base --is-ancestor` that commit is 305 commits back in this
# branch's own history, and the .dtype property is present in this tip.
SOFTWARE_REPO_URL=git@github.sambanovasystems.com:SambaNova/software.git
SOFTWARE_REPO_BRANCH=josephp/nova/ddr_alloc_mem2mem_AND_bar2_mappings_AND_scaleout_refactor_AND_atrpatch_AND_ScatterGatherGraph_Jul5_2026
SOFTWARE_REPO_COMMIT=7058fff1052b33cc6b9a3432ed6b1143908c0deb  # tip as of 2026-07-14

# coe_api/rdu_engine unconditionally wants a memcopy PEF and a scatter-gather
# PEF at session init (vllm-rdu's own always_load_memcopy_pef(True), plus
# coe_api's own unconditional scatter-gather-app establishment -- neither is
# model-specific, both depend only on hardware topology: arch=sn40,
# vsnodes=16, interleave=1 for this cluster). Compiling them ourselves
# requires building this repo's entire compiler backend (transitively pulls
# in @pytorch), which hits a genuine "undeclared inclusion(s)" build failure
# in pytorch's own BUILD.bazel at this pinned commit -- see build/bar2.sh's
# stage_utility_pefs comment for the full story. So: build/bar2.sh stages
# pre-built copies from here instead (a BUILD-TIME-only input -- never
# passed into the Docker image or read at container runtime, unlike a
# runtime env var). Points at josephp's own already-built utility-PEF
# directory (NFS, world-readable, confirmed) -- same pattern this repo
# already uses for jayr's model PEF/checkpoint (personal scratch space, not
# a shared/versioned location -- see README's "Component repos" caveat).
# Revisit (or finish debugging the pytorch build failure) if this path ever
# moves or becomes unavailable.
UTILITY_PEF_SOURCE_DIR=/import/ml-sc-scratch6/josephp/install_roots_pool/josephp_docker3_install/bazel-install/pefs

# bazelisk: neither the login node nor RDU nodes have `bazel` on PATH by
# default. bazelisk reads the software repo's own .bazelversion (8.5.1) and
# transparently downloads/caches the matching real bazel release.
BAZELISK_VERSION=1.20.0
BAZELISK_URL=https://github.com/bazelbuild/bazelisk/releases/download/v1.20.0/bazelisk-linux-amd64
BAZELISK_SHA256=d9af1fa808c0529753c3befda75123236a711d971d3485a390507122148773a3

# rhel810-dev: SambaNova's officially-supported dev container. Has
# /opt/sambanova (torch==2.2.0+sn, mpich, llvm19) already correctly
# populated -- used both as the BAR2 self-build container (build/bar2.sh)
# and as docker/rdu/Dockerfile's base image, so the RDU decode image doesn't need
# to separately source torch's provenance.
RHEL810_DEV_IMAGE=artifacts.sambanovasystems.com/sw-docker/rhel810-dev:latest

# SambaNova's bnxt_re RDMA userland replacement (see docker/rdu/Dockerfile) -- same
# package/version referenced in SambaNova/software's own
# docker/runtime/rhel810-sn40plus/Containerfile and
# modelbox/docker/base/rhel810/Containerfile. Verified 2026-07-06 by an
# actual `dnf install` test: the files it provides are byte-identical
# (sha256) to what this repo used to vendor directly as a binary blob.
BRCM_ROCE_USERLAND_VERSION=233.0.152.2-1.el8

# ── Python packages ───────────────────────────────────────────────────────────
# GPU side: torch/flashinfer/deepgemm are locked inside vllm/vllm-openai Docker image.
VLLM_VERSION=0.16.0           # vllm Docker image base tag
DYNAMO_VERSION=1.2.1          # ai-dynamo + ai-dynamo-runtime (control plane + RDU venv)

# GPU-prefill-side KV cache CPU-tier offload (docker/gpu/Dockerfile). NOT
# latest (0.5.1) -- deliberately pinned to 0.3.15, a patch release on top of
# 0.3.14, the exact version already pre-installed inside vllm/vllm-openai:0.16.0
# itself (confirmed: `pip install lmcache==0.5.1` in an earlier attempt showed
# "Found existing installation: lmcache 0.3.14" being uninstalled first).
#
# Root cause, confirmed by direct repro + LMCache source inspection: our
# torch build here is 2.9.1+cu129 (CUDA 12.9, libcudart.so.12). LMCache's
# default PyPI wheel from 0.4.5 onward targets CUDA 13 (cupy-cuda13x /
# nixl-cu13 deps, c_ops.so wanting libcudart.so.13) -- that .so fails to
# import at actual GPU-node runtime (confirmed via a torch C++ ABI symbol
# mismatch, not just a missing-library error -- even a CUDA-12.9-specific
# GitHub Release build of 0.5.1 still hit this), and LMCache's own pluggable
# backend loader silently substitutes its pure-Python reference
# implementation for every compiled op -- which has a real, currently
# unmerged gap for the "HND" KV-cache layout NixlConnector requires for
# non-MLA models (EngineDeadError: "HND layouts ... are not supported in the
# non-CUDA fallback", LMCache PR #3790 open as of 2026-07-02).
#
# 0.3.14/0.3.15 avoid all of this: their requires_dist is plain `nixl` (no
# CUDA-version suffix, matching our own from-source-built nixl package name)
# + cupy-cuda12x (matching our actual CUDA 12.9 runtime) -- confirmed via
# PyPI metadata, not guessed. Their compiled c_ops.so predates LMCache's HND
# kernel work entirely (PR #2826, merged 2026-03-26, well after 0.3.15's
# 2026-03-02 release), so it has no distinct code path for the HND layout
# NixlConnector forces -- validated empirically (test/e2e_lmcache_correctness.py)
# that it still produces correct output via a generic/layout-agnostic path
# rather than silently mishandling it. If a future bump past this pin
# reintroduces the crash or a correctness regression, an earlier
# v0.4.6-cu129..v0.5.0-cu129 GitHub Release build (postdates the HND kernel
# fix, predates the CUDA-13 dependency switch) or a from-source build against
# this image's exact torch are the next things to try.
LMCACHE_VERSION=0.3.15

# ── Python packages — RDU side ────────────────────────────────────────────────
RDU_NUMPY_VERSION=1.26.4      # CRITICAL: system numpy 2.x binary-incompatible with torch 2.2.0+sn
RDU_TRANSFORMERS_VERSION=4.56.0

# ── rdma-core devel headers (downloaded by build/rdu_env.sh --fetch-only,
#    SHA256-verified). RHEL8 RDU nodes ship libibverbs/librdmacm runtime .so.1
#    (matching this exact version, confirmed via SONAME 1.14.48.0/1.3.48.0)
#    but not the -devel headers, and no package manager access to install them.
#    We only need a handful of public headers to compile UCX's verbs transport
#    against — see build/rdu_env.sh for the exact file list.  ──
RDMA_CORE_VERSION=48.0
RDMA_CORE_URL=https://github.com/linux-rdma/rdma-core/archive/refs/tags/v48.0.tar.gz
RDMA_CORE_SHA256=e78abaa3ed16771bc6c40b538fe27082429363b86b6ce47636bb57a59238b2be

# ── Infrastructure (fetched by docker/control-plane/Dockerfile, SHA256-verified) ──
ETCD_VERSION=3.5.15
ETCD_SHA256=435d74510f3216bab1932fb6d7a6b5fe8245301143fcd25f7e65dfb7dcf8904a

NATS_VERSION=2.14.3
NATS_SHA256=588b858328bc507ddff3b6078cda7db762f28e6da8c3fa368099a204f0f37a37
