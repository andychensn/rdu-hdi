#!/usr/bin/env bash
# Cluster topology for rdu-hdi.
# Edit GPU_NODE, RDU_NODE, RoCE IPs, and reservations for your setup.
# Source alongside versions.env and model.env in launch scripts.

# ── Control plane (login node) ───────────────────────────────────────────────
CONTROL_PLANE_IP=10.10.0.156       # IP of the node running etcd/NATS/frontend

# ── Ports ─────────────────────────────────────────────────────────────────────
ETCD_PORT=12379
NATS_PORT=14222
VLLM_PORT=18000

# ── GPU prefill node ──────────────────────────────────────────────────────────
GPU_NODE=sc3-c129
GPU_ROCE_IP=10.17.176.33           # bnxt_re0 RoCE IP of the GPU node
GPU_PARTITION=gpuonly
GPU_RESERVATION=RDU-prefill-experiment-test
GPU_GRES=gpu:4
GPU_TIME=04:00:00
GPU_PREFILL_REGISTER_TIMEOUT=600   # seconds to wait for worker registration

# ── GPU prefill Docker image ───────────────────────────────────────────────────
# Built by: bash scripts/build_docker_gpu.sh
# Tag scheme: v{VLLM_VERSION}-rdu-hdi.{N} — increment N on UCX/NIXL/patch changes
# Edit GPU_IMAGE_TAG only; GPU_IMAGE is derived from it.
GPU_IMAGE_TAG=v0.16.0-rdu-hdi.3
GPU_IMAGE=sc-artifacts2.sambanovasystems.com/sw-docker-scratch/rdu-hdi-gpu-prefill:${GPU_IMAGE_TAG}

# ── RDU decode node ───────────────────────────────────────────────────────────
RDU_NODE=sc3-s339
RDU_ROCE_IP=10.17.112.29           # bnxt_re0 RoCE IP of the RDU node
RDU_PARTITION=zd3
RDU_QOS=5
RDU_RESERVATION=no_sf_catchup_demos
RDU_TIMEOUT=01:50:00

# ── BAR2 / SambaFlow SDK paths (RDU hardware SDK, like CUDA for GPU) ──────────
# These are set by the snrdu environment on the RDU node.
# Override here if your cluster uses different paths.
# (SOFTWARE_BUILD removed 2026-07-02 — was only used for etcd-cpp-api/gflags
# libs that nothing in this stack actually depends on; UCX/NIXL always use
# our own repo-built rdu-ucx-install/ now. See git history if ever needed.)
# (BAR2_INSTALL removed 2026-07-03 — was jayr's ad-hoc NFS tree
# (/import/snvm-sc-scratch2/jayr/sambaflow_gTkgyGCEBH/bazel-install). coe_api/
# rdu_engine now come from .venv_rdu's own site-packages (pip install
# wheelhouse/sambanova_{rdu_engine_api,coe_api}-*.whl, self-built by
# scripts/build_bar2.sh from the pinned SambaNova/software commit — see
# config/versions.env SOFTWARE_REPO_* and docs/local/DOCKERIZE_BAR2_PLAN.md).
# BAR2_INSTALL/lib must NOT be added back to rdu_decode.sh's LD_LIBRARY_PATH:
# it has its own older libCoEApi.so/libNovaRuntime.so that silently wins the
# dlopen over our wheel's bundled .libs/ (LD_LIBRARY_PATH is consulted before
# any library's own RUNPATH, and RUNPATH is non-transitive) — caused
# `undefined symbol: _ZN4nova7coe_api21ScatterGatherScheduleD1Ev` at RDU
# decode launch even though a standalone `import coe_api` worked fine.
#
# BAR2_RUNTIME_LIBS/BAR2_PRELOAD: self-built from the same pinned commit
# (runtime/build.py 'graph' target group + extra runtime-only .so exports),
# replacing guoyaof's ad-hoc NFS trees these used to point at.
BAR2_RUNTIME_LIBS=/import/snvm-sc-scratch1/andyc/rdu-hdi/rdu-runtime-install/lib
BAR2_PRELOAD=/import/snvm-sc-scratch1/andyc/rdu-hdi/rdu-runtime-install/lib

# ── Runtime paths (relative to REPO_ROOT, all gitignored) ─────────────────────
# .venv_cp/   — control plane venv (auto-created by control_plane.sh)
# .venv_rdu/  — RDU decode venv (built by build_rdu_env.sh --build-only on RDU node)
# .gpu_cache/ — GPU prefill caches (mounted into Docker container via /import)
