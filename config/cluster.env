#!/usr/bin/env bash
# Cluster-specific configuration for rdu-hdi.
# Source alongside versions.env in launch scripts.
# Update GPU_ROCE_IP when switching GPU nodes.

CONTROL_PLANE_IP=10.10.0.156       # sc-vnc9 login node

# GPU node
GPU_NODE=sc3-c129                  # c129 is in RDU-prefill-experiment-test reservation
GPU_ROCE_IP=10.17.176.33           # c129 bnxt_re0/brcm0 RoCE IP
# Note: c127 (GPU_ROCE_IP=10.17.176.29) can be used without reservation
GPU_PARTITION=gpuonly
GPU_RESERVATION=RDU-prefill-experiment-test
GPU_GRES=gpu:4
GPU_TIME=04:00:00
GPU_PREFILL_REGISTER_TIMEOUT=600   # 10 min: model load + DeepGEMM warmup

# GPU prefill Docker image (built by scripts/build_docker_gpu.sh, pushed to internal registry)
# Tag scheme: v{VLLM_VERSION}-rdu-hdi.{N} — increment N when UCX/NIXL commits or vllm patch changes
# GPU_IMAGE is derived from GPU_IMAGE_TAG — edit GPU_IMAGE_TAG, not GPU_IMAGE directly.
GPU_IMAGE_TAG=v0.16.0-rdu-hdi.1
GPU_IMAGE=sc-artifacts2.sambanovasystems.com/sw-docker-scratch/rdu-hdi-gpu-prefill:${GPU_IMAGE_TAG}

# RDU node
RDU_NODE=sc3-s339
RDU_ROCE_IP=10.17.112.29           # s339 bnxt_re0 RoCE IP
RDU_PARTITION=zd3
RDU_QOS=5
RDU_RESERVATION=no_sf_catchup_demos
RDU_TIMEOUT=01:50:00               # Hard limit for reservation

# Model
MODEL=/import/ml-sc-scratch6/yund/checkpoints/MiniMax-M2.7
SERVED_MODEL_NAME=MiniMax-M2.7
PEF=/import/ml-sc-scratch4/jayr/minimax_m2__full_layers_tp16_ssss_cg_ss_max_ss_tg_parallel_sdk_fp8_per_tensor/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608.pef

# vLLM settings
TENSOR_PARALLEL_SIZE=4
MAX_MODEL_LEN=196608
MAX_NUM_BATCHED_TOKENS=4096
BLOCK_SIZE=64
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_SEQS=1

# Ports
ETCD_PORT=12379
NATS_PORT=14222
VLLM_PORT=18000

# Paths (relative to REPO_ROOT, set by each script)
# GPU_VENV=$REPO_ROOT/.venv_gpu
# RDU_VENV=$REPO_ROOT/.venv_rdu
# UCX_INSTALL=$REPO_ROOT/ucx-install
