#!/usr/bin/env bash
# Cluster topology for rdu-hdi.
# Edit GPU_NODES, RDU_NODE, RoCE IPs, and reservations for your setup.
# Source alongside versions.env and model.env in launch scripts.

# ── Control plane (login node) ───────────────────────────────────────────────
CONTROL_PLANE_IP=10.10.0.156       # IP of the node running etcd/NATS/frontend

# ── Ports ─────────────────────────────────────────────────────────────────────
ETCD_PORT=12379
NATS_PORT=14222
VLLM_PORT=18000

# ── GPU prefill node(s) ─────────────────────────────────────────────────────────
# One entry per prefill worker, index-paired. Empty string in GPU_RESERVATIONS
# omits --reservation entirely for that worker (some nodes need no reservation).
GPU_NODES=(sc3-c129 sc3-c129)
GPU_RESERVATIONS=(RDU-prefill-experiment-test RDU-prefill-experiment-test)
GPU_ROCE_IP=10.17.176.33           # bnxt_re0 RoCE IP of the GPU node — only feeds the optional
                                    # chunk-overlap prewarm shortcut (see docs/local/XPYD_SCALING_DESIGN.md
                                    # §4); with >1 prefill worker, only the one at this IP gets the
                                    # prewarm benefit, not a correctness issue.
GPU_PARTITION=gpuonly
GPU_GRES=gpu:4
GPU_MEM=400G                       # explicit --mem so multiple concurrent same-node jobs schedule
                                    # promptly (omitting --mem makes SLURM default to ~half the
                                    # node's memory per job, starving concurrent jobs — see
                                    # docs/local/GPU_PREFILL_PARITY_INVESTIGATION.md)
GPU_NIXL_BASE_PORT=5600            # NIXL side-channel port base; worker i uses BASE+i to avoid
                                    # same-node port collisions (vLLM's own default is a fixed 5600
                                    # for every worker when data_parallel_index=0)
GPU_TIME=04:00:00
GPU_PREFILL_REGISTER_TIMEOUT=600   # seconds to wait for worker registration

# ── GPU prefill Docker image ───────────────────────────────────────────────────
# Built by: bash docker/gpu/build.sh
# Tag scheme: v{VLLM_VERSION}-rdu-hdi.{N} — increment N on UCX/NIXL/patch changes
# Edit GPU_IMAGE_TAG only; GPU_IMAGE is derived from it.
GPU_IMAGE_TAG=v0.16.0-rdu-hdi.3
GPU_IMAGE=sc-artifacts2.sambanovasystems.com/sw-docker-scratch/rdu-hdi-gpu-prefill:${GPU_IMAGE_TAG}

# ── Control-plane Docker image (etcd + NATS + Dynamo frontend) ────────────────
# Built by: bash docker/control-plane/build.sh
# Tag scheme: v{DYNAMO_VERSION}-rdu-hdi.{N} — increment N on etcd/NATS/dynamo changes
CONTROL_PLANE_IMAGE_TAG=v1.2.1-rdu-hdi.1
CONTROL_PLANE_IMAGE=sc-artifacts2.sambanovasystems.com/sw-docker-scratch/rdu-hdi-control-plane:${CONTROL_PLANE_IMAGE_TAG}

# ── RDU decode Docker image ────────────────────────────────────────────────────
# Built by: bash docker/rdu/build.sh
# Tag scheme: v{DYNAMO_VERSION}-rdu-hdi.{N} — increment N on vllm/dynamo/fast-coe/UCX/NIXL/BAR2 changes
# Bakes in coe_api/rdu_engine + the BAR2 runtime connector libs (self-built,
# see build/bar2.sh and config/versions.env's SOFTWARE_REPO_* comment).
RDU_IMAGE_TAG=v1.2.1-rdu-hdi.2
RDU_IMAGE=sc-artifacts2.sambanovasystems.com/sw-docker-scratch/rdu-hdi-rdu-decode:${RDU_IMAGE_TAG}

# ── RDU decode node ───────────────────────────────────────────────────────────
RDU_NODE=sc3-s339
RDU_ROCE_IP=10.17.112.29           # bnxt_re0 RoCE IP of the RDU node
RDU_PARTITION=zd3
RDU_QOS=5
RDU_RESERVATION=no_sf_catchup_demos
RDU_TIMEOUT=01:55:00                # SLURM job time limit (snrdu --timeout) -- the zd3 partition
                                    # hard-caps at MaxTime=02:00:00, so this can't go higher. A
                                    # timeout orphans the Docker container (SLURM stops tracking
                                    # it, but it keeps serving requests with no logging and no way
                                    # to cleanly restart it) -- relaunch proactively before ~2h of
                                    # continuous use rather than relying on this alone.
RDU_DECODE_REGISTER_TIMEOUT=1500   # seconds to wait for worker registration (~12-14 min typical)

# ── Runtime paths (relative to REPO_ROOT, all gitignored) ─────────────────────
# .gpu_cache/ — GPU prefill caches (mounted into Docker container via /import)
