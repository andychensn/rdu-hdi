#!/usr/bin/env bash
# Cluster topology for rdu-hdi.
# Edit GPU_NODES, RDU_NODE, RoCE IPs, and reservations for your setup.
# Source alongside versions.env and model.env in launch scripts.

# ── Control plane (login node) ───────────────────────────────────────────────
CONTROL_PLANE_IP=10.10.0.156       # IP of the node running etcd/NATS/frontend

# ── Ports ─────────────────────────────────────────────────────────────────────
ETCD_PORT=12379
NATS_PORT=14222
VLLM_PORT=18000

# ── GPU prefill node(s) ─────────────────────────────────────────────────────────
# One entry per prefill worker, index-paired. Empty string in GPU_RESERVATIONS
# omits --reservation entirely for that worker (some nodes need no reservation).
# sc3-c128 needs "vllm-stuff" (a separate shared reservation covering
# sc3-c[126,128],sc3-s345) -- it is not reservation-free the way it once was.
GPU_NODES=(sc3-c129 sc3-c129 sc3-c128 sc3-c128)
GPU_RESERVATIONS=(RDU-prefill-experiment-test RDU-prefill-experiment-test vllm-stuff vllm-stuff)
GPU_ROCE_IP=10.17.176.33           # bnxt_re0 RoCE IP of the GPU node — only feeds the optional
                                    # chunk-overlap prewarm shortcut; with >1 prefill worker, only
                                    # the one at this IP gets the prewarm benefit, not a
                                    # correctness issue.
GPU_PARTITION=gpuonly
GPU_GRES=gpu:4                     # per-worker GPU count. For single-worker GPU_EXPLICIT_DEVICES
                                    # combo testing (see launch/gpu_prefill.sh), temporarily bump
                                    # this to gpu:8 (whole node) and drop to a single GPU_NODES
                                    # entry -- every physical GPU must be in the job's cgroup device
                                    # whitelist for an arbitrary combo override to work.
GPU_CPUS=16                          # CPUs requested per prefill worker (TP4 => 4 cores/GPU).
                                    # Default used to be an implicit 2 (0.5 cores/GPU) since no
                                    # --cpus-per-task was ever passed -- this is a single bigger
                                    # allocation on the SAME step (no nested srun). Bumped to 16
                                    # while root-causing a per-request-compute-time growth issue
                                    # (CPU core count turned out not to be the cause -- 16 cores
                                    # produced the same growth curve as 2 -- but 16 is harmless and
                                    # gives numactl headroom, so kept as the default).
GPU_NUMA_SWAP_TEST=0                # Causal NUMA-affinity test (see launch/gpu_prefill.sh's
                                    # --inner block for the full mapping/rationale): deliberately
                                    # mismatches each worker's CPU/mem NUMA binding from its
                                    # actual GPUs' native NUMA node, computed at runtime from
                                    # $CUDA_VISIBLE_DEVICES (SLURM assigns physical GPUs
                                    # per-launch, not fixed per worker index). Set to 0 to disable
                                    # and use SLURM's natural (unbound) cgroup CPU assignment.
                                    # (NUMA affinity was ruled out as the cause of the compute-time
                                    # growth issue above -- root cause was a single GPU per node
                                    # thermally throttling under sustained load -- kept because the
                                    # override mechanism itself is reusable for future causal tests.)
GPU_MEM=400G                       # explicit --mem so multiple concurrent same-node jobs schedule
                                    # promptly (omitting --mem makes SLURM default to ~half the
                                    # node's memory per job, starving concurrent jobs)
GPU_NIXL_BASE_PORT=5600            # NIXL side-channel port base; worker i uses BASE+i to avoid
                                    # same-node port collisions (vLLM's own default is a fixed 5600
                                    # for every worker when data_parallel_index=0)
GPU_KV_EVENTS_BASE_PORT=5557       # KV-events ZMQ publisher port base (feeds --router-mode kv's
                                    # cache-aware routing); worker i uses BASE+i -- same collision
                                    # pattern as GPU_NIXL_BASE_PORT, vLLM's KVEventsConfig defaults
                                    # every worker to a fixed tcp://*:5557
GPU_TIME=04:00:00                  # must stay comfortably above GPU_PREFILL_REGISTER_TIMEOUT below
                                    # -- if this is ever lowered for a faster-turnaround test config,
                                    # a job that SLURM kills mid-registration reads as a generic
                                    # "worker exited early" error with no hint the real cause is a
                                    # timeout/job-length mismatch.
GPU_PREFILL_REGISTER_TIMEOUT=1800  # seconds to wait for worker registration. 600s was enough for
                                    # every prior launch, all on sc3-c129, which has loaded this
                                    # checkpoint repeatedly across this whole project's history
                                    # (warm NFS-client page cache). The first-ever load on a
                                    # different node took >10min just for safetensors checkpoint
                                    # loading (cold cache reading from the same shared /import/...
                                    # path) -- bumped to tolerate a genuine cold-node first load
                                    # rather than a hang. Tradeoff: a worker that's genuinely hung
                                    # (not just slow) now takes up to 30min to be caught and torn
                                    # down, vs. 10min before.

# ── GPU prefill Docker image ───────────────────────────────────────────────────
# Built by: bash docker/gpu/build.sh
# Tag scheme: v{VLLM_VERSION}-rdu-hdi.{N} — increment N on UCX/NIXL/patch changes
# Edit GPU_IMAGE_TAG only; GPU_IMAGE is derived from it.
GPU_IMAGE_TAG=v0.16.0-rdu-hdi.4
GPU_IMAGE=sc-artifacts2.sambanovasystems.com/sw-docker-scratch/rdu-hdi-gpu-prefill:${GPU_IMAGE_TAG}

# ── Control-plane Docker image (etcd + NATS + Dynamo frontend) ────────────────
# Built by: bash docker/control-plane/build.sh
# Tag scheme: v{DYNAMO_VERSION}-rdu-hdi.{N} — increment N on etcd/NATS/dynamo changes
CONTROL_PLANE_IMAGE_TAG=v1.2.1-rdu-hdi.2
CONTROL_PLANE_IMAGE=sc-artifacts2.sambanovasystems.com/sw-docker-scratch/rdu-hdi-control-plane:${CONTROL_PLANE_IMAGE_TAG}

# ── RDU decode Docker image ────────────────────────────────────────────────────
# Built by: bash docker/rdu/build.sh
# Tag scheme: v{DYNAMO_VERSION}-rdu-hdi.{N} — increment N on vllm/dynamo/fast-coe/UCX/NIXL/BAR2 changes
# Bakes in coe_api/rdu_engine + the BAR2 runtime connector libs (self-built,
# see build/bar2.sh and config/versions.env's SOFTWARE_REPO_* comment).
RDU_IMAGE_TAG=v1.2.1-rdu-hdi.2
RDU_IMAGE=sc-artifacts2.sambanovasystems.com/sw-docker-scratch/rdu-hdi-rdu-decode:${RDU_IMAGE_TAG}

# ── RDU decode node ───────────────────────────────────────────────────────────
RDU_NODE=sc3-s339
RDU_ROCE_IP=10.17.112.29           # bnxt_re0 RoCE IP of the RDU node
RDU_PARTITION=zd3
RDU_QOS=5
RDU_RESERVATION=no_sf_catchup_demos
RDU_TIMEOUT=01:55:00                # SLURM job time limit (snrdu --timeout) -- the zd3 partition
                                    # hard-caps at MaxTime=02:00:00, so this can't go higher. A
                                    # timeout orphans the Docker container (SLURM stops tracking
                                    # it, but it keeps serving requests with no logging and no way
                                    # to cleanly restart it) -- relaunch proactively before ~2h of
                                    # continuous use rather than relying on this alone.
RDU_DECODE_REGISTER_TIMEOUT=1500   # seconds to wait for worker registration (~12-14 min typical)

# ── Runtime paths (relative to REPO_ROOT, all gitignored) ─────────────────────
# .gpu_cache/ — GPU prefill caches (mounted into Docker container via /import)
