#!/usr/bin/env bash
# Model-specific configuration for rdu-hdi.
# Edit this file when switching to a different model or PEF.
# Source alongside cluster.env and versions.env in launch scripts.

# ── Model checkpoint ──────────────────────────────────────────────────────────
MODEL=/import/ml-sc-scratch6/yund/checkpoints/MiniMax-M2.7
SERVED_MODEL_NAME=MiniMax-M2.7

# ── RDU compiled model (PEF) ──────────────────────────────────────────────────
# Path to the .pef file compiled for this model's topology.
PEF=/import/ml-sc-scratch4/jayr/minimax_m2__full_layers_tp16_ssss_cg_ss_max_ss_tg_parallel_sdk_fp8_per_tensor/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608.pef

# ── RDU model config ──────────────────────────────────────────────────────────
# Model-specific YAML for the RDU decode worker.
# To add a new model: copy config/minimax_m2.yaml, adapt for your model,
# and point MODEL_CONFIG at the new file.
MODEL_CONFIG="$REPO_ROOT/config/minimax_m2.yaml"

# ── vLLM / inference settings ─────────────────────────────────────────────────
TENSOR_PARALLEL_SIZE=4        # number of GPU TP shards for prefill
MAX_MODEL_LEN=196608          # max sequence length
MAX_NUM_BATCHED_TOKENS=4096
BLOCK_SIZE=64                 # KV cache block size for GPU prefill's own vLLM engine.
                               # RDU decode's real block size is a hardcoded 256 (a
                               # physical RDU memory-paging constant, force-applied
                               # regardless of any CLI flag -- see
                               # fast-coe/server/vllm-rdu/rdu_hardware/platform.py).
                               # Dynamo's KV router builds its prefill cache-affinity
                               # logic from whichever value decode announces, not
                               # prefill's real value, so a naive mismatch here would
                               # silently break cross-worker cache-aware routing.
                               # Fixed via launch/rdu_decode.sh + docker/rdu/
                               # entrypoint.sh + install-deps.sh: decode announces
                               # this same BLOCK_SIZE value to Dynamo's discovery
                               # layer (via --additional-config's
                               # dynamo_kv_event_block_size key) without touching its
                               # own real cache_config.block_size=256, so its actual
                               # NIXL KV-transfer geometry is untouched. If you change
                               # BLOCK_SIZE here, no further changes are needed
                               # elsewhere -- decode picks it up automatically. Do NOT
                               # instead try to raise this to 256 to match decode
                               # directly: that crashes RDU decode's NIXL KV transfer
                               # (NIXL_ERR_INVALID_PARAM) -- SambaNova's connector fork
                               # is built and tested for a block-size mismatch and has
                               # an apparently-untested/broken matched-size path.
GPU_MEMORY_UTILIZATION=0.90
# Note: RDU decode's --max-num-seqs is hardcoded to 2 in
# docker/rdu/entrypoint.sh, not read from here.
