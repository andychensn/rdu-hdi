#!/usr/bin/env bash
# Model-specific configuration for rdu-hdi.
# Edit this file when switching to a different model or PEF.
# Source alongside cluster.env and versions.env in launch scripts.

# ── Model checkpoint ──────────────────────────────────────────────────────────
MODEL=/import/ml-sc-scratch6/yund/checkpoints/MiniMax-M2.7
SERVED_MODEL_NAME=MiniMax-M2.7

# ── RDU compiled model (PEF) ──────────────────────────────────────────────────
# Path to the .pef file compiled for this model's topology.
PEF=/import/ml-sc-scratch4/jayr/minimax_m2__full_layers_tp16_ssss_cg_ss_max_ss_tg_parallel_sdk_fp8_per_tensor/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608/minimax-m2__full_layers_TP16_ssSS_CG_SS_MAX_SS_TG_parallel_sdk_fp8_per_tensor_CoE_ckpt_sharing_BS2_SSSS_CG_max196608_SS_MAX_max196608_SS_TG_max196608.pef

# ── RDU model config ──────────────────────────────────────────────────────────
# Model-specific YAML for the RDU decode worker -- vllm-rdu's flat RduConfig
# schema (rdu_executor/config.py), not fast-coe's rdu_manifest.model_registry
# schema (config/minimax_m2.yaml, kept for reference during the migration).
# To add a new model: copy config/minimax_m2_vllm_rdu.yaml, adapt for your
# model, and point
# MODEL_CONFIG at the new file.
MODEL_CONFIG="$REPO_ROOT/config/minimax_m2_vllm_rdu.yaml"

# ── vLLM / inference settings ─────────────────────────────────────────────────
TENSOR_PARALLEL_SIZE=4        # number of GPU TP shards for prefill
MAX_MODEL_LEN=196608          # max sequence length
MAX_NUM_BATCHED_TOKENS=4096
BLOCK_SIZE=64                 # KV cache block size for GPU prefill's own vLLM engine.
                               # RDU decode's real block size is a hardcoded 256 (a
                               # physical RDU memory-paging constant), passed explicitly
                               # via docker/rdu/entrypoint.sh's --block-size 256 flag --
                               # vllm-rdu's RDUPlatform (vllm_rdu/platform.py) only
                               # VALIDATES this against the PEF's real page size (raises
                               # ValueError if missing/wrong), it does not force-set it
                               # the way fast-coe's platform.py used to.
                               # Dynamo's KV router builds its prefill cache-affinity
                               # logic from whichever value decode announces, not
                               # prefill's real value, so a naive mismatch here would
                               # silently break cross-worker cache-aware routing.
                               # Fixed via launch/rdu_decode.sh + docker/rdu/
                               # entrypoint.sh + install-deps.sh: decode announces
                               # this same BLOCK_SIZE value to Dynamo's discovery
                               # layer (via --additional-config's
                               # dynamo_kv_event_block_size key) without touching its
                               # own real cache_config.block_size=256, so its actual
                               # NIXL KV-transfer geometry is untouched. If you change
                               # BLOCK_SIZE here, no further changes are needed
                               # elsewhere -- decode picks it up automatically. Do NOT
                               # instead try to raise this to 256 to match decode
                               # directly: that crashes RDU decode's NIXL KV transfer
                               # (NIXL_ERR_INVALID_PARAM) -- SambaNova's connector fork
                               # is built and tested for a block-size mismatch and has
                               # an apparently-untested/broken matched-size path.
GPU_MEMORY_UTILIZATION=0.90
# Note: RDU decode's --max-num-seqs is hardcoded to 2 in
# docker/rdu/entrypoint.sh, not read from here.

# ── LMCache (GPU-prefill-side KV cache CPU-tier offload) ──────────────────────
# GPU prefill only -- composed with NixlConnector via vLLM's native
# MultiConnector (see launch/gpu_prefill.sh's KV_CONFIG). RDU decode is
# untouched. See config/versions.env's LMCACHE_VERSION comment for the
# version-pin story. LMCACHE_CHUNK_SIZE is derived from BLOCK_SIZE in
# launch/gpu_prefill.sh (must be an exact multiple -- LMCache raises
# ValueError otherwise), not set here, so it can't drift out of sync if
# BLOCK_SIZE ever changes.
# Placeholder, not yet sized against a real measured working set -- generous
# enough for initial correctness testing, revisit before relying on this for
# a real workload's cache-hit rate.
LMCACHE_MAX_LOCAL_CPU_GB=20
# Local-disk tier, layered UNDER the CPU tier (LMCache always keeps
# local_cpu as a buffer for other backends -- this is not an either/or
# choice). 0 disables it entirely.
#
# When >0, launch/gpu_prefill.sh mounts a per-worker-scoped
# $GPU_CACHE_ROOT/lmcache_disk/worker$IDX (NFS path) and passes
# LMCACHE_LOCAL_DISK/LMCACHE_MAX_LOCAL_DISK_SIZE through to LMCache.
# Confirmed working end-to-end (LMCACHE_LOG_LEVEL=DEBUG, real "Disk write
# size"/"Disk read size" lines + a genuine "Retrieved N/N required tokens"
# ground-truth line + matching completion text on replay, after forcing a
# real CPU-tier eviction with a tiny LMCACHE_MAX_LOCAL_CPU_GB -- disabling
# native prefix caching, GPU_DISABLE_NATIVE_PREFIX_CACHE=1, is required for
# this to mean anything, same caveat as test/e2e_lmcache_correctness.py).
# See also test/smoke_lmcache_tiers.py for a lightweight sanity check of
# both tiers.
#
# Real limitation, confirmed directly against LocalDiskBackend's own source
# (lmcache==0.3.15): its key->file-path index (self.dict) is populated only
# by what THIS process itself has written -- it is NOT rebuilt by scanning
# the directory at startup. So the .pt files on disk genuinely persist
# across a worker container restart, but a freshly restarted process has
# no way to discover/reuse them -- they become invisible dead weight (not
# reclaimed until a new write happens to reuse the exact same content-hash
# key and physically overwrites the file, or the path is cleaned
# manually). Confirmed empirically: a resend of an already-cached prompt
# to a FRESH process reported a clean miss (LMCache hit tokens: 0) and
# re-wrote the same file, rather than reading it back -- do not assume
# disk-tier warmth survives a relaunch.
#
# Placeholder size, not yet sized against a real measured working set --
# NFS-backed so there's plenty of headroom, but revisit before relying on
# this for a real workload's cache-hit rate (same caveat as
# LMCACHE_MAX_LOCAL_CPU_GB above).
LMCACHE_MAX_LOCAL_DISK_GB=100
